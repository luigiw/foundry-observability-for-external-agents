# GitHub Copilot SDK Local Agent — Environment Configuration

# -----------------------------------------------------------------------
# Required: Azure Application Insights connection string
# Get this from: Azure Portal → App Insights resource → Overview → Connection string
# -----------------------------------------------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<your-key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;...

# -----------------------------------------------------------------------
# Trace export mode (default: otlp — requires docker-compose up)
#   otlp         → Python app + Copilot CLI both send to OTel Collector sidecar
#                  which forwards everything to App Insights (recommended)
#   azure_monitor → Python app sends directly to App Insights;
#                  Copilot CLI spans are NOT sent to App Insights
# -----------------------------------------------------------------------
OTEL_EXPORTER=otlp

# -----------------------------------------------------------------------
# Set to "true" to capture user input and assistant response text as span
# attributes — required for App Insights-based eval (eval/run_eval.py).
# Keep "false" in production if inputs/outputs are sensitive.
# -----------------------------------------------------------------------
OTEL_CAPTURE_CONTENT=false

# -----------------------------------------------------------------------
# OTel Collector OTLP HTTP endpoint (only used when OTEL_EXPORTER=otlp)
# Default matches docker-compose.yml port mapping.
# -----------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# -----------------------------------------------------------------------
# Optional: Override the service name shown in App Insights
# -----------------------------------------------------------------------
OTEL_SERVICE_NAME=copilot-local-agent

# -----------------------------------------------------------------------
# Optional: Path to the Copilot CLI binary.
# If not set, the SDK uses the bundled binary or PATH.
# -----------------------------------------------------------------------
# COPILOT_CLI_PATH=/usr/local/bin/gh-copilot-cli

# -----------------------------------------------------------------------
# Optional: GitHub token for authentication.
# If not set, uses the currently logged-in GitHub account (gh auth login).
# -----------------------------------------------------------------------
# GITHUB_TOKEN=ghp_...

# -----------------------------------------------------------------------
# Optional: Model to use (default: gpt-5)
# -----------------------------------------------------------------------
COPILOT_MODEL=gpt-5

# -----------------------------------------------------------------------
# Optional: Also dump CLI spans to a local JSONL file for debugging.
# -----------------------------------------------------------------------
# COPILOT_TRACE_FILE=traces.jsonl
