# -----------------------------------------------------------------------
# App Insights — required for app-insights eval mode
# Azure Portal → App Insights → API Access
# -----------------------------------------------------------------------
APPLICATIONINSIGHTS_APP_ID=<your-app-id>
APPLICATIONINSIGHTS_QUERY_API_KEY=<your-read-telemetry-api-key>

# -----------------------------------------------------------------------
# App Insights resource ID — required for trace-based batch eval
# Azure Portal → App Insights → Properties → Resource ID
# Format: /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Insights/components/<name>
# -----------------------------------------------------------------------
APPINSIGHTS_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Insights/components/<name>

# -----------------------------------------------------------------------
# Agent ID filter for trace eval — matches gen_ai.agent.id set by OTel collector
# -----------------------------------------------------------------------
AGENT_ID=hw-copilot-cli

# -----------------------------------------------------------------------
# LLM judge — pick ONE provider
# -----------------------------------------------------------------------

# Option A: Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Option B: GPT-5 via Azure AI Foundry unified endpoint (--model-provider gpt5)
AZURE_GPT5_ENDPOINT=https://<resource>.openai.azure.com/openai/v1/
AZURE_GPT5_API_KEY=<key>
AZURE_GPT5_DEPLOYMENT=gpt-5

# -----------------------------------------------------------------------
# Remote eval — log results to Azure AI Foundry (--azure-ai-project flag)
# Azure AI Foundry → your project → Overview → Project endpoint
# -----------------------------------------------------------------------
AZURE_AI_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project-name>
