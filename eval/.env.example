# ── LLM Judge — Azure OpenAI (use with --model-provider azure-openai) ──────────
# Azure OpenAI deployment used as the LLM judge (e.g. gpt-4o, gpt-4)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── LLM Judge — Azure AI Foundry / Anthropic (use with --model-provider foundry)
# Re-uses the same Azure AI Foundry resource as the GCP agent.
# These default to the values in gcp/langgraph-customer-support/.env if not set here.
AZURE_FOUNDRY_RESOURCE=<your-foundry-resource-name>
AZURE_FOUNDRY_API_KEY=<your-foundry-api-key>
# Model routed through the local proxy (default: claude-haiku-4-5)
# PROXY_MODEL=claude-haiku-4-5
# Local proxy port (default: 4000)
# PROXY_PORT=4000

# ── LLM Judge — GPT-5 via Azure AI Foundry (use with --model-provider gpt5) ──
# Uses the new /openai/v1/ unified endpoint (model specified in body, no api-version).
AZURE_GPT5_ENDPOINT=https://<your-resource>.openai.azure.com/openai/v1/
AZURE_GPT5_API_KEY=<your-api-key>
AZURE_GPT5_DEPLOYMENT=gpt-5

# ── App Insights query (required for --mode app-insights) ───────────────────
# Found in Azure Portal → Application Insights → API Access
# App ID: shown on the API Access page
APPLICATIONINSIGHTS_APP_ID=<your-app-insights-application-id>
# Create a query-only API key via API Access → "Create API key"
# Grant "Read telemetry" permission
APPLICATIONINSIGHTS_QUERY_API_KEY=<your-api-key>

# ── AWS agent (required for --agent aws --mode live) ────────────────────────────
# AWS credentials should be configured via ~/.aws/credentials or the env vars below
# AWS_ACCESS_KEY_ID=<your-access-key>
# AWS_SECRET_ACCESS_KEY=<your-secret-key>
AWS_DEFAULT_REGION=us-east-1

# ── GCP agent (required for --agent gcp --mode live) ───────────────────────────
# These override the values in gcp/langgraph-customer-support/.env when set here
# AZURE_FOUNDRY_RESOURCE=<your-foundry-resource-name>
# AZURE_FOUNDRY_API_KEY=<your-foundry-api-key>
