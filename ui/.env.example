# ── Azure OpenAI — judge LLM for trace evaluation (Compare page) ──────────────
# Required for the "Evaluate a Trace" button on the Compare page.
# Create a deployment in your Azure OpenAI resource and fill these in:
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>   # e.g. gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-01            # optional, default shown
